<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.nzbdav"
       name="NZB-DAV Repository"
       version="1.1.2"
       provider-name="nzbdav">
    <requires>
        <import addon="xbmc.addon" version="12.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="NZB-DAV Repository">
        <dir>
            <info compressed="true">https://ponchopig.github.io/nzbdavkodi/addons.xml.gz</info>
            <checksum verify="sha256">https://ponchopig.github.io/nzbdavkodi/addons.xml.gz.sha256</checksum>
            <datadir zip="true">https://ponchopig.github.io/nzbdavkodi/</datadir>
            <hashes>sha256</hashes>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">NZB-DAV addon repository</summary>
        <description lang="en_GB">Install and update the NZB-DAV Kodi addon.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
