<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.nzbdav"
       name="NZB-DAV Repository"
       version="1.1.0"
       provider-name="nzbdav">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.addon.repository" name="NZB-DAV Repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/xbmc4lyfe/nzbdavkodi/main/repo/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/xbmc4lyfe/nzbdavkodi/main/repo/zips/addons.xml.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/xbmc4lyfe/nzbdavkodi/main/repo/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">NZB-DAV addon repository</summary>
        <description lang="en_GB">Install and update the NZB-DAV Kodi addon.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
        </assets>
    </extension>
</addon>
