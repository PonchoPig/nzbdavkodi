<settings version="2">
    <setting id="nzbhydra_enabled">true</setting>
    <setting id="hydra_url">${HYDRA_URL}</setting>
    <setting id="hydra_api_key">${HYDRA_API_KEY}</setting>
    <setting id="prowlarr_enabled" default="true">false</setting>
    <!-- These URLs are docker-network-internal hostnames since the addon
         runs inside the kodi container (bridge network). The host can
         still reach the same services via localhost:8180 and
         localhost:8280 (port-mapped in docker-compose.yml). -->
    <setting id="nzbdav_url">http://nzbdav-rs:8080</setting>
    <setting id="nzbdav_api_key">${NZBDAV_API_KEY}</setting>
    <setting id="webdav_url">http://fault-proxy:8280/dav</setting>
    <setting id="webdav_username">${WEBDAV_USERNAME}</setting>
    <setting id="webdav_password">${WEBDAV_PASSWORD}</setting>
    <!-- Filter biases the runtime release pick toward simple SDR H.264.
         In the headless Xvfb container Kodi uses Mesa llvmpipe (software
         OpenGL) + FFmpeg software decode. HDR (HDR10/HDR10+/Dolby Vision)
         and HEVC/AV1 paths exercise GL extensions and 10-bit decoders
         that Kodi 21 fails on llvmpipe with — the resulting GL context
         breakdown crashes Kodi after setResolvedUrl. Locking to SDR +
         AVC keeps the render path on the most exercised software path.
         Re-enable everything when running this test on a real GPU host. -->
    <setting id="filter_2160p">false</setting>
    <setting id="filter_1080p">true</setting>
    <setting id="filter_720p">true</setting>
    <setting id="filter_480p">true</setting>
    <setting id="filter_hdr10">false</setting>
    <setting id="filter_hdr10plus">false</setting>
    <setting id="filter_dolby_vision">false</setting>
    <setting id="filter_hlg">false</setting>
    <setting id="filter_sdr">true</setting>
    <setting id="filter_atmos">true</setting>
    <setting id="filter_truehd">true</setting>
    <setting id="filter_dtshd_ma">true</setting>
    <setting id="filter_dtsx">true</setting>
    <setting id="filter_ddplus">true</setting>
    <setting id="filter_dd">true</setting>
    <setting id="filter_aac">true</setting>
    <setting id="filter_hevc">false</setting>
    <!-- AVC disabled, AV1 only. The addon's auto_select_best ranks
         release-quality fields (resolution, codec, source) and picks the
         single highest-scoring filtered result. With AVC enabled, every
         WEB-DL AVC 1080p result outscores the AV1 BluRay alternatives —
         and WEB-DL releases (GPRS/AMZN/etc.) produce NZBs whose PAR2 file
         descriptors don't include clean filenames, so nzbdav-rs's
         deobfuscator returns "no importable video file found". The
         dAV1nci AV1 BluRay NZBs ship with clean descriptors that
         nzbdav-rs handles, so we force the addon onto that path. -->
    <setting id="filter_avc">false</setting>
    <setting id="filter_av1">true</setting>
    <setting id="filter_vp9">false</setting>
    <setting id="filter_mpeg2">true</setting>
    <setting id="filter_english">true</setting>
    <!-- Disable size filtering for the extreme test: the orchestrator
         picks random IMDB Top 50 movies whose releases vary widely in size
         (e.g. 1962's Harakiri ships well under 10 GB), and the test's
         pre-flight _addon_settings() doesn't set these, so a 10-17 GB
         band would reject everything at runtime even though pre-flight
         saw releases. Filter is a quality knob, not part of fault-recovery
         behaviour under test. -->
    <setting id="filter_min_size">0</setting>
    <setting id="filter_max_size">0</setting>
    <setting id="max_results">25</setting>
    <setting id="auto_select_best" default="true">true</setting>
    <setting id="poll_interval">1</setting>
    <setting id="download_timeout">3600</setting>
    <setting id="submit_timeout">120</setting>
    <setting id="cache_ttl">300</setting>
    <setting id="stream_auto_retry">true</setting>
    <setting id="stream_max_retries">3</setting>
    <setting id="stream_retry_delay">5</setting>
    <setting id="fallback_streams_enabled">true</setting>
    <setting id="fallback_streams_max">8</setting>
    <setting id="proxy_convert_subs">true</setting>
    <setting id="force_remux_threshold_mb">15000</setting>
    <setting id="strict_contract_mode">1</setting>
    <setting id="zero_fill_budget_enabled">true</setting>
    <setting id="retry_ladder_enabled">true</setting>
    <setting id="install_tmdbhelper" default="true">false</setting>
</settings>
