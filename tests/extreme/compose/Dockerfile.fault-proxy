FROM python:3.12-slim

RUN useradd --create-home --uid 10001 appuser \
    && mkdir -p /app /var/log/fault-proxy \
    && chown -R appuser:appuser /app /var/log/fault-proxy

WORKDIR /app
COPY fault_proxy.py /app/fault_proxy.py

USER appuser

EXPOSE 19080 19081

CMD ["python3", "/app/fault_proxy.py"]
