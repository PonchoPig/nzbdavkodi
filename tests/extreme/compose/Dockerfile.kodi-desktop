FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    ca-certificates \
    curl \
    && add-apt-repository -y ppa:ubuntuhandbook1/kodi \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
    kodi \
    kodi-bin \
    x11-utils \
    xvfb \
    x11vnc \
    novnc \
    websockify \
    supervisor \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /var/log/supervisor /root/.kodi/addons /root/.kodi/userdata

RUN printf '%s\n' \
    'pcm.!default {' \
    '  type null' \
    '}' \
    'ctl.!default {' \
    '  type null' \
    '}' \
    > /etc/asound.conf

COPY compose/supervisord.conf /etc/supervisor/conf.d/supervisord.conf

# Bake Kodi userdata fixtures into the image. The /root/.kodi named volume
# inherits these on first init; a bind mount would let Kodi mutate the host
# fixture (566-line bloat after every shutdown), and a read-only bind mount
# blocks Kodi's shutdown writes enough to break the kodi_ready 60s window.
COPY fixtures/guisettings.xml /root/.kodi/userdata/guisettings.xml
COPY fixtures/sources.xml /root/.kodi/userdata/sources.xml

EXPOSE 5900 6901 8080

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]
