# Required for `just extreme-functional-test` (and the existing functional-test recipes).
# Copy this file to .env (which is gitignored) and fill in real values, OR
# point EXTREME_ENV_FILE at an existing .env elsewhere on disk.

# NZBHydra2 instance (LAN or local)
HYDRA_URL=http://192.168.1.93:5076
HYDRA_API_KEY=

# nzbdav-rs API key — anything; must match docker-compose env
NZBDAV_API_KEY=smokekey-dev-only

# Eweka (or other NNTP provider) credentials
NNTP_HOST=news.eweka.nl
NNTP_PORT=563
NNTP_USER=
NNTP_PASS=
NNTP_CONNS=50

# WebDAV credentials nzbdav-rs serves under (also fed to the addon)
WEBDAV_USERNAME=admin
WEBDAV_PASSWORD=devpass

# TMDB API key (TMDBHelper requires this for movie lookup)
TMDB_API_KEY=

# Optional: deterministic seed. Defaults to int(time.time()) per run.
# EXTREME_SEED=42

# Optional: bound assertions. Unset = pure measurement mode.
# EXTREME_MAX_RESUME_SECONDS=30
# EXTREME_MAX_FREEZE_SECONDS=10

# Optional: alternate env file location. Defaults to ./env
# EXTREME_ENV_FILE=/Users/allen/nzbdav-real-e2e/.env
